<!-- Sidebar -->
<nav id="sidebar">
  <div class="sidebar-header text-center py-4">
    <a href="/" class="text-decoration-none">
      <h4 class="text-white mb-0"><i class="bi bi-shop text-primary me-2"></i>Clothing ERP</h4>
      <small class="text-muted">Stock Management</small>
    </a>
  </div>

  <div class="px-3 py-2 text-center text-white-50 border-bottom border-secondary border-opacity-10">
    <div class="fw-bold text-light"><%= currentUser.name %></div>
    <div class="badge bg-secondary bg-opacity-25 text-white-50 mt-1 small"><%= currentUser.role %></div>
    <% if (currentUser.branch_id) { %>
      <div class="mt-1 small text-info"><i class="bi bi-geo-alt-fill me-1"></i><%= currentUser.branch_id.branch_name %></div>
    <% } else { %>
      <div class="mt-1 small text-warning"><i class="bi bi-shield-lock-fill me-1"></i>All Branches</div>
    <% } %>
  </div>

  <ul class="nav flex-column mt-3">
    <li class="nav-item">
      <a class="nav-link" href="/">
        <i class="bi bi-speedometer2"></i>
        <span>Dashboard</span>
      </a>
    </li>

    <% if (currentUser.role === 'Super Admin') { %>
      <li class="nav-item mt-2">
        <div class="px-4 py-1 text-uppercase text-muted fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.05rem;">Administration</div>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/branches">
          <i class="bi bi-buildings-fill"></i>
          <span>Manage Branches</span>
        </a>
      </li>
      <li class="nav-item">
        <a class="nav-link" href="/branches/users">
          <i class="bi bi-people-fill"></i>
          <span>Manage Users</span>
        </a>
      </li>
    <% } %>

    <li class="nav-item mt-2">
      <div class="px-4 py-1 text-uppercase text-muted fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.05rem;">Inventory</div>
    </li>
    <li class="nav-item">
      <a class="nav-link" href="/stocks">
        <i class="bi bi-box-seam-fill"></i>
        <span>View Stock</span>
      </a>
    </li>
    <% if (currentUser.role !== 'Staff User') { %>
      <li class="nav-item">
        <a class="nav-link" href="/stocks/upload">
          <i class="bi bi-file-earmark-arrow-up-fill"></i>
          <span>Upload Stock Excel</span>
        </a>
      </li>
    <% } %>

    <li class="nav-item mt-2">
      <div class="px-4 py-1 text-uppercase text-muted fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.05rem;">Sales</div>
    </li>
    <li class="nav-item">
      <a class="nav-link" href="/sales">
        <i class="bi bi-cart-fill"></i>
        <span>Sales Log</span>
      </a>
    </li>
    <% if (currentUser.role !== 'Staff User') { %>
      <li class="nav-item">
        <a class="nav-link" href="/sales/upload">
          <i class="bi bi-file-earmark-plus-fill"></i>
          <span>Upload Sales Excel</span>
        </a>
      </li>
    <% } %>

    <li class="nav-item mt-2">
      <div class="px-4 py-1 text-uppercase text-muted fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.05rem;">Logistics</div>
    </li>
    <li class="nav-item">
      <a class="nav-link" href="/transfers">
        <i class="bi bi-arrow-left-right"></i>
        <span>Stock Transfers</span>
      </a>
    </li>

    <li class="nav-item mt-2">
      <div class="px-4 py-1 text-uppercase text-muted fw-bold small" style="font-size: 0.75rem; letter-spacing: 0.05rem;">Reporting</div>
    </li>
    <li class="nav-item">
      <a class="nav-link" href="/reports">
        <i class="bi bi-file-earmark-bar-graph-fill"></i>
        <span>Reports Center</span>
      </a>
    </li>

    <li class="nav-item mt-4 border-top border-secondary border-opacity-10 pt-3">
      <a class="nav-link text-danger" href="/auth/logout">
        <i class="bi bi-box-arrow-left"></i>
        <span>Sign Out</span>
      </a>
    </li>
  </ul>
</nav>

<!-- Mobile sidebar backdrop -->
<div id="sidebar-overlay" class="sidebar-overlay" aria-hidden="true"></div>

<script>
  // Highlight active link in sidebar based on current URL path
  document.addEventListener('DOMContentLoaded', function() {
    const currentPath = window.location.pathname;
    const links = document.querySelectorAll('#sidebar .nav-link');
    links.forEach(link => {
      const href = link.getAttribute('href');
      if (currentPath === href || (href !== '/' && currentPath.startsWith(href))) {
        link.classList.add('active');
      }
    });
  });
</script>
