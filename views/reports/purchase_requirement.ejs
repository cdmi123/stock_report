<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div id="content-wrapper">
  <%- include('../partials/navbar') %>

  <div class="container-fluid p-4 fade-in-up">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <h4 class="fw-bold mb-0"><i class="bi bi-bag-plus me-2 text-dark"></i>Purchase Requirements Report</h4>
      <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to Hub</a>
    </div>

    <!-- Alert Explanation -->
    <div class="alert alert-info border-0 shadow-sm mb-4" role="alert" style="border-radius: 12px;">
      <i class="bi bi-info-circle-fill me-2 fs-5"></i>
      <strong>Procurement Suggestion Engine:</strong> This report identifies products where the total consolidated stock across all branches is low (<= 2) or where any individual branch has a negative stock (outstanding customer order shortages).
    </div>

    <!-- Report Table -->
    <div class="erp-card">
      <div class="table-responsive">
        <table class="table table-hover align-middle datatable table-bordered">
          <thead class="table-dark text-nowrap">
            <tr>
              <th>Barcode</th>
              <th>Item Name</th>
              <th>Design No</th>
              <th>Size</th>
              <th>Colour</th>
              <th class="text-end bg-danger bg-opacity-10 text-danger">Total Stock</th>
              <th class="text-end bg-success bg-opacity-10 text-success">Suggested Purchase Qty</th>
              <th>Branch stock details</th>
            </tr>
          </thead>
          <tbody>
            <% data.forEach(row => { %>
              <tr class="<%= row.totalQuantity < 0 ? 'table-danger' : '' %>">
                <td class="font-monospace small"><%= row.product.barcode || '-' %></td>
                <td class="fw-bold"><%= row.product.item_name %></td>
                <td><span class="badge bg-secondary bg-opacity-25 text-dark font-monospace"><%= row.product.design_no %></span></td>
                <td class="fw-bold"><%= row.product.size %></td>
                <td><%= row.product.colour || '-' %></td>
                <td class="text-end fw-bold bg-danger bg-opacity-5 <%= row.totalQuantity < 0 ? 'text-danger' : '' %>">
                  <%= row.totalQuantity %>
                </td>
                <td class="text-end fw-bold text-success bg-success bg-opacity-5">
                  <%= row.suggestedPurchaseQty %> pcs
                </td>
                <td class="small">
                  <div class="d-flex flex-wrap gap-2">
                    <% row.branches.forEach(b => { %>
                      <% let qty = row.branchQuantities[b._id.toString()] || 0; %>
                      <span class="badge <%= qty < 0 ? 'bg-danger' : (qty === 0 ? 'bg-secondary bg-opacity-25 text-dark' : 'bg-primary bg-opacity-10 text-primary') %> px-2 py-1">
                        <%= b.branch_name %>: <strong><%= qty %></strong>
                      </span>
                    <% }) %>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
