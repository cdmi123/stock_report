<%- include('../partials/header') %>
<%- include('../partials/sidebar') %>

<div id="content-wrapper">
  <%- include('../partials/navbar') %>

  <div class="container-fluid p-4 fade-in-up">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
      <h4 class="fw-bold mb-0"><i class="bi bi-activity me-2 text-success"></i>Fast Moving Products Report</h4>
      <a href="/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Back to Hub</a>
    </div>

    <!-- Filter (Super Admin only) -->
    <% if (role === 'Super Admin') { %>
      <div class="erp-card mb-4">
        <form action="/reports/fast-moving" method="GET" class="row g-3 align-items-end">
          <div class="col-md-8">
            <label for="branchId" class="form-label fw-semibold small text-muted text-uppercase">Filter by Branch</label>
            <select class="form-select" id="branchId" name="branchId">
              <option value="">All Branches</option>
              <% branches.forEach(b => { %>
                <option value="<%= b._id %>" <%= selectedBranch === b._id.toString() ? 'selected' : '' %>><%= b.branch_name %> (<%= b.city %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-4">
            <button type="submit" class="btn btn-primary w-100 py-2"><i class="bi bi-funnel-fill me-1"></i>Generate Report</button>
          </div>
        </form>
      </div>
    <% } %>

    <!-- Report Table -->
    <div class="erp-card">
      <div class="table-responsive">
        <table class="table table-hover align-middle datatable">
          <thead>
            <tr>
              <th>Rank</th>
              <th>Barcode</th>
              <th>Item Name</th>
              <th>Design No</th>
              <th>Size</th>
              <th>Colour</th>
              <th class="text-end">Units Sold (30 Days)</th>
              <th class="text-end">Rate</th>
              <th class="text-end text-success">Total Revenue</th>
            </tr>
          </thead>
          <tbody>
            <% data.forEach((row, index) => { %>
              <tr>
                <td class="fw-bold text-muted"><%= index + 1 %></td>
                <td class="font-monospace small"><%= row.product.barcode || '-' %></td>
                <td class="fw-bold"><%= row.product.item_name %></td>
                <td><span class="badge bg-secondary bg-opacity-25 text-dark font-monospace"><%= row.product.design_no %></span></td>
                <td class="fw-semibold"><%= row.product.size %></td>
                <td><%= row.product.colour || '-' %></td>
                <td class="text-end fw-bold text-primary"><%= row.totalSold %></td>
                <td class="text-end">₹<%= row.product.rate.toFixed(2) %></td>
                <td class="text-end fw-semibold text-success">
                  ₹<%= (row.totalSold * row.product.rate).toLocaleString('en-IN') %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

  </div>
</div>

<%- include('../partials/footer') %>
